@model Project
@{ ViewData["Title"] = "Matched Project Details"; }

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-success border-2 shadow-sm">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-stars"></i> Matched Project</h5>
            </div>
            <div class="card-body p-4">
                <h4>@Model.Title</h4>
                <p class="text-muted">@Model.Abstract</p>
                <hr />
                <div class="row g-3">
                    <div class="col-sm-6">
                        <strong>Tech Stack:</strong><br />
                        @foreach (var t in Model.TechStack.Split(','))
                        {
                            <span class="badge bg-primary me-1">@t.Trim()</span>
                        }
                    </div>
                    <div class="col-sm-6">
                        <strong>Research Area:</strong><br />
                        <span class="badge bg-info text-dark fs-6">@Model.ResearchArea?.Name</span>
                    </div>
                </div>
                <hr />
                <div class="card bg-success bg-opacity-10 border-0">
                    <div class="card-body">
                        <h6 class="text-success"><i class="bi bi-person-badge"></i> Student Details (Revealed)</h6>
                        <p class="mb-1"><strong>Name:</strong> @Model.Student?.FullName</p>
                        <p class="mb-0"><strong>Email:</strong>
                            <a href="mailto:@Model.Student?.Email">@Model.Student?.Email</a>
                        </p>
                    </div>
                </div>
                <div class="mt-3">
                    <strong>Matched on:</strong> @Model.MatchedAt?.ToString("dd MMM yyyy HH:mm")
                </div>
            </div>
        </div>
        <a asp-action="Dashboard" class="btn btn-outline-secondary mt-3">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>
