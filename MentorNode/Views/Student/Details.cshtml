@model Project
@{ ViewData["Title"] = "Proposal Details"; }

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3>@Model.Title</h3>
            @{
                var badgeClass = Model.Status switch
                {
                    ProjectStatus.Pending     => "bg-secondary",
                    ProjectStatus.UnderReview => "bg-warning text-dark",
                    ProjectStatus.Matched     => "bg-success",
                    ProjectStatus.Withdrawn   => "bg-danger",
                    _                         => "bg-dark"
                };
            }
            <span class="badge @badgeClass fs-6">@Model.Status</span>
        </div>

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small mb-2">Abstract</h6>
                <p>@Model.Abstract</p>

                <hr />

                <div class="row g-2 small">
                    <div class="col-sm-6">
                        <strong> Tech Stack:</strong><br />
                        @foreach (var tech in Model.TechStack.Split(','))
                        {
                            <span class="badge bg-primary bg-opacity-75 me-1">@tech.Trim()</span>
                        }
                    </div>
                    <div class="col-sm-6">
                        <strong> Research Area:</strong><br />
                        <span class="badge bg-info text-dark">@Model.ResearchArea?.Name</span>
                    </div>
                    <div class="col-sm-6 mt-2">
                        <strong> Submitted:</strong>
                        @Model.SubmittedAt.ToString("dd MMM yyyy HH:mm")
                    </div>
                    @if (Model.MatchedAt.HasValue)
                    {
                        <div class="col-sm-6 mt-2">
                            <strong> Matched:</strong>
                            @Model.MatchedAt.Value.ToString("dd MMM yyyy HH:mm")
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (Model.Status == ProjectStatus.Matched && Model.IdentityRevealed && Model.Supervisor is not null)
        {
            <div class="card border-success border-2 bg-success bg-opacity-10 mb-3">
                <div class="card-body">
                    <h6 class="text-success"> Your Supervisor (Identity Revealed)</h6>
                    <p class="mb-1"><strong>Name:</strong> @Model.Supervisor.FullName</p>
                    <p class="mb-0"><strong>Email:</strong>
                        <a href="mailto:@Model.Supervisor.Email">@Model.Supervisor.Email</a>
                    </p>
                </div>
            </div>
        }
        else if (Model.Status == ProjectStatus.UnderReview)
        {
            <div class="alert alert-warning">
                
                A supervisor has expressed interest. Identity will be revealed upon confirmation.
            </div>
        }

        <a asp-action="Dashboard" class="btn btn-outline-secondary">
             Back to Dashboard
        </a>
    </div>
</div>
