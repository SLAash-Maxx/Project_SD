@model CreateUserViewModel
@{ ViewData["Title"] = "Create User"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-person-plus"></i> Create New Account</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="CreateUser" method="post">
                    <div asp-validation-summary="All" class="alert alert-danger small"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control" autofocus />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Role" class="form-label fw-semibold"></label>
                        <select asp-for="Role" class="form-select">
                            <option value="Student">Student</option>
                            <option value="Supervisor">Supervisor</option>
                            <option value="ModuleLeader">Module Leader</option>
                            @if (User.IsInRole("SystemAdmin"))
                            {
                                <option value="SystemAdmin">System Admin</option>
                            }
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                        <div class="form-text">Min 8 chars, uppercase, digit, and special character.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Create Account
                        </button>
                        <a class="btn btn-outline-secondary" onclick="history.back()">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
