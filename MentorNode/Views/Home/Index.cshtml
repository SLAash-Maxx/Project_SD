@{
    ViewData["Title"] = "Welcome";
}

<div class="text-center py-5">
    <div class="display-1 mb-3">
        <img src="~/image/logo.png" alt="BlindMatch logo" class="img-fluid" style="max-width: 200px;" />
    </div>
    <h1 class="display-5 fw-bold">Project Approval System</h1>
    <p class="h3 text-muted mb-4">NSBM Green University</p>
    <div class="mt-4 d-flex justify-content-center gap-3 flex-wrap">
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-5">
            Sign In
        </a>
        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-secondary btn-lg px-5">
            Register as Student
        </a>
    </div>
</div>

<hr class="my-5" />

<div class="row g-4 text-center">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body py-4">
                <h5 class="card-title">Students Submit</h5>
                <p class="card-text text-muted">
                    Submit your research proposal with title, abstract, technology stack, and research area.
                    Track your status in real time.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body py-4">
                <h5 class="card-title">Supervisors Review Blindly</h5>
                <p class="card-text text-muted">
                    Supervisors browse proposals anonymously — no student names visible.
                    Selection is based purely on technical merit and area alignment.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body py-4">
                <h5 class="card-title">Identity Revealed on Match</h5>
                <p class="card-text text-muted">
                    Once a supervisor confirms interest, both parties' identities are revealed
                    and formal collaboration can begin.
                </p>
            </div>
        </div>
    </div>
</div>

